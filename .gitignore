# Firebase — do NOT commit service account / admin credentials
# (client config in lib/firebase_options.dart and android/app/google-services.json
# are safe to commit — they are not secret keys, security is enforced by
# Firestore Rules and App Check, not by hiding them)
**/serviceAccountKey.json
**/*-firebase-adminsdk-*.json

